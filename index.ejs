<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Students</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100">
  <nav class="bg-blue-600 text-white p-4">
    <div class="container mx-auto flex justify-between items-center">
      <h1 class="text-2xl font-bold">School Fees Management</h1>
      <div class="flex gap-4 items-center">
        <a href="/dashboard" class="hover:underline">Dashboard</a>
        <a href="/students" class="hover:underline">Students</a>
        <% if (user.role === 'admin') { %>
        <a href="/classes" class="hover:underline">Classes</a>
        <a href="/staff" class="hover:underline">Staff</a>
        <% } %>
        <span class="text-sm">(<%= user.username %>)</span>
        <a href="/auth/logout" class="bg-red-500 px-4 py-2 rounded hover:bg-red-600">Logout</a>
      </div>
    </div>
  </nav>

  <div class="container mx-auto p-6">
    <% if (success && success.length > 0) { %>
    <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-4">
      <%= success %>
    </div>
    <% } %>
    
    <% if (error && error.length > 0) { %>
    <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4">
      <%= error %>
    </div>
    <% } %>

    <div class="flex justify-between items-center mb-6">
      <h2 class="text-3xl font-bold">Students</h2>
      <% if (user.role === 'admin' || user.permissions.canAddStudent) { %>
      <a href="/students/add" class="bg-blue-600 text-white px-6 py-2 rounded hover:bg-blue-700">
        Add Student
      </a>
      <% } %>
    </div>

    <div class="bg-white p-4 rounded-lg shadow mb-6">
      <form method="GET" class="flex gap-4 flex-wrap">
        <input type="text" name="search" placeholder="Search by name or reg number" 
               value="<%= search %>"
               class="flex-1 min-w-[200px] px-4 py-2 border rounded focus:outline-none focus:ring-2 focus:ring-blue-500">
        <select name="classFilter" class="px-4 py-2 border rounded focus:outline-none focus:ring-2 focus:ring-blue-500">
          <option value="">All Classes</option>
          <% classes.forEach(classItem => { %>
          <option value="<%= classItem._id %>" <%= classFilter === classItem._id.toString() ? 'selected' : '' %>>
            <%= classItem.name %>
          </option>
          <% }) %>
        </select>
        <select name="level" class="px-4 py-2 border rounded focus:outline-none focus:ring-2 focus:ring-blue-500">
          <option value="">All Levels</option>
          <option value="Level 3" <%= level === 'Level 3' ? 'selected' : '' %>>Level 3</option>
          <option value="Level 4" <%= level === 'Level 4' ? 'selected' : '' %>>Level 4</option>
          <option value="Level 5" <%= level === 'Level 5' ? 'selected' : '' %>>Level 5</option>
        </select>
        <button type="submit" class="bg-blue-600 text-white px-6 py-2 rounded hover:bg-blue-700">
          Search
        </button>
        <a href="/students" class="bg-gray-500 text-white px-6 py-2 rounded hover:bg-gray-600">
          Clear
        </a>
      </form>
    </div>

    <div class="bg-white rounded-lg shadow overflow-x-auto">
      <table class="w-full">
        <thead class="bg-gray-200">
          <tr>
            <th class="px-4 py-3 text-left">Reg Number</th>
            <th class="px-4 py-3 text-left">Full Name</th>
            <th class="px-4 py-3 text-left">Class</th>
            <th class="px-4 py-3 text-left">Level</th>
            <th class="px-4 py-3 text-right">Total Fees</th>
            <th class="px-4 py-3 text-right">Amount Paid</th>
            <th class="px-4 py-3 text-right">Balance</th>
            <th class="px-4 py-3 text-left">Date Registered</th>
            <th class="px-4 py-3 text-center">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% if (students.length === 0) { %>
          <tr>
            <td colspan="9" class="px-4 py-8 text-center text-gray-500">No students found</td>
          </tr>
          <% } else { %>
          <% students.forEach(student => { %>
          <tr class="border-t hover:bg-gray-50">
            <td class="px-4 py-3"><%= student.registrationNumber %></td>
            <td class="px-4 py-3"><%= student.fullName %></td>
            <td class="px-4 py-3"><%= student.class ? student.class.name : 'N/A' %></td>
            <td class="px-4 py-3"><%= student.level %></td>
            <td class="px-4 py-3 text-right"><%= student.totalFees.toFixed(2) %> FRW</td>
            <td class="px-4 py-3 text-right"><%= student.amountPaid.toFixed(2) %> FRW</td>
            <td class="px-4 py-3 text-right <%= student.balance > 0 ? 'text-red-600 font-bold' : 'text-green-600' %>">
              <%= student.balance.toFixed(2) %> FRW
            </td>
            <td class="px-4 py-3"><%= new Date(student.dateRegistered).toLocaleDateString() %></td>
            <td class="px-4 py-3">
              <div class="flex gap-2 justify-center">
                <% if (user.role === 'admin' || user.permissions.canRecordPayment) { %>
                <a href="/students/payment/<%= student._id %>" 
                   class="bg-green-500 text-white px-3 py-1 rounded text-sm hover:bg-green-600">
                  Pay
                </a>
                <% } %>
                <% if (user.role === 'admin' || user.permissions.canEditStudent) { %>
                <a href="/students/edit/<%= student._id %>" 
                   class="bg-yellow-500 text-white px-3 py-1 rounded text-sm hover:bg-yellow-600">
                  Edit
                </a>
                <% } %>
                <% if (user.role === 'admin' || user.permissions.canDeleteStudent) { %>
                <form method="POST" action="/students/delete/<%= student._id %>" class="inline"
                      onsubmit="return confirm('Are you sure you want to delete this student?')">
                  <button type="submit" 
                          class="bg-red-500 text-white px-3 py-1 rounded text-sm hover:bg-red-600">
                    Delete
                  </button>
                </form>
                <% } %>
              </div>
            </td>
          </tr>
          <% }) %>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</body>
</html>
