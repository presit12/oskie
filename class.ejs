<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= classItem.name %> Report</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100">
  <nav class="bg-blue-600 text-white p-4">
    <div class="container mx-auto flex justify-between items-center">
      <h1 class="text-2xl font-bold">School Fees Management</h1>
      <div class="flex gap-4 items-center">
        <a href="/dashboard" class="hover:underline">Dashboard</a>
        <a href="/students" class="hover:underline">Students</a>
        <a href="/reports" class="hover:underline">Reports</a>
        <% if (user.role === 'admin') { %>
        <a href="/classes" class="hover:underline">Classes</a>
        <a href="/staff" class="hover:underline">Staff</a>
        <% } %>
        <a href="/auth/logout" class="bg-red-500 px-4 py-2 rounded hover:bg-red-600">Logout</a>
      </div>
    </div>
  </nav>

  <div class="container mx-auto p-6">
    <div class="flex justify-between items-center mb-6">
      <div>
        <h2 class="text-3xl font-bold"><%= classItem.name %> - Class Report</h2>
        <p class="text-gray-600">Class Fees: <%= classItem.fees.toFixed(2) %> FRW</p>
      </div>
      <div class="flex gap-2">
        <a href="/reports" class="bg-gray-500 text-white px-6 py-2 rounded hover:bg-gray-600">
          Back to Reports
        </a>
        <button onclick="window.print()" class="bg-blue-600 text-white px-6 py-2 rounded hover:bg-blue-700">
          Print Report
        </button>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-6">
      <div class="bg-white p-6 rounded-lg shadow">
        <p class="text-gray-600 text-sm">Total Students</p>
        <p class="text-3xl font-bold text-blue-600"><%= totalStudents %></p>
      </div>
      <div class="bg-white p-6 rounded-lg shadow">
        <p class="text-gray-600 text-sm">Total Expected</p>
        <p class="text-3xl font-bold text-purple-600"><%= totalFees.toFixed(2) %> FRW</p>
      </div>
      <div class="bg-white p-6 rounded-lg shadow">
        <p class="text-gray-600 text-sm">Total Collected</p>
        <p class="text-3xl font-bold text-green-600"><%= totalPaid.toFixed(2) %> FRW</p>
      </div>
      <div class="bg-white p-6 rounded-lg shadow">
        <p class="text-gray-600 text-sm">Outstanding</p>
        <p class="text-3xl font-bold text-red-600"><%= totalBalance.toFixed(2) %> FRW</p>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
      <div class="bg-green-50 border-2 border-green-200 p-6 rounded-lg">
        <p class="text-green-800 font-bold text-lg">Fully Paid</p>
        <p class="text-4xl font-bold text-green-600"><%= fullyPaidCount %></p>
        <p class="text-sm text-green-700">Students with no balance</p>
      </div>
      <div class="bg-yellow-50 border-2 border-yellow-200 p-6 rounded-lg">
        <p class="text-yellow-800 font-bold text-lg">Partially Paid</p>
        <p class="text-4xl font-bold text-yellow-600"><%= partiallyPaidCount %></p>
        <p class="text-sm text-yellow-700">Students with partial payment</p>
      </div>
      <div class="bg-red-50 border-2 border-red-200 p-6 rounded-lg">
        <p class="text-red-800 font-bold text-lg">Not Paid</p>
        <p class="text-4xl font-bold text-red-600"><%= notPaidCount %></p>
        <p class="text-sm text-red-700">Students with no payment</p>
      </div>
    </div>

    <div class="bg-white p-6 rounded-lg shadow mb-6">
      <h3 class="text-xl font-bold mb-4">Breakdown by Level</h3>
      <table class="w-full">
        <thead class="bg-gray-200">
          <tr>
            <th class="px-4 py-2 text-left">Level</th>
            <th class="px-4 py-2 text-center">Students</th>
            <th class="px-4 py-2 text-right">Total Paid</th>
            <th class="px-4 py-2 text-right">Balance</th>
          </tr>
        </thead>
        <tbody>
          <% levelBreakdown.forEach(item => { %>
          <tr class="border-t">
            <td class="px-4 py-2 font-bold"><%= item.level %></td>
            <td class="px-4 py-2 text-center"><%= item.studentCount %></td>
            <td class="px-4 py-2 text-right text-green-600"><%= item.totalPaid.toFixed(2) %> FRW</td>
            <td class="px-4 py-2 text-right text-red-600"><%= item.totalBalance.toFixed(2) %> FRW</td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <div class="bg-white p-6 rounded-lg shadow">
      <h3 class="text-xl font-bold mb-4">Student Payment Details</h3>
      <div class="overflow-x-auto">
        <table class="w-full">
          <thead class="bg-gray-200">
            <tr>
              <th class="px-4 py-2 text-left">Reg Number</th>
              <th class="px-4 py-2 text-left">Full Name</th>
              <th class="px-4 py-2 text-left">Level</th>
              <th class="px-4 py-2 text-right">Total Fees</th>
              <th class="px-4 py-2 text-right">Amount Paid</th>
              <th class="px-4 py-2 text-right">Balance</th>
              <th class="px-4 py-2 text-center">Status</th>
            </tr>
          </thead>
          <tbody>
            <% if (students.length === 0) { %>
            <tr>
              <td colspan="7" class="px-4 py-8 text-center text-gray-500">No students in this class</td>
            </tr>
            <% } else { %>
            <% students.forEach(student => { %>
            <tr class="border-t hover:bg-gray-50">
              <td class="px-4 py-2"><%= student.registrationNumber %></td>
              <td class="px-4 py-2"><%= student.fullName %></td>
              <td class="px-4 py-2"><%= student.level %></td>
              <td class="px-4 py-2 text-right"><%= student.totalFees.toFixed(2) %> FRW</td>
              <td class="px-4 py-2 text-right text-green-600"><%= student.amountPaid.toFixed(2) %> FRW</td>
              <td class="px-4 py-2 text-right <%= student.balance > 0 ? 'text-red-600 font-bold' : 'text-green-600' %>">
                <%= student.balance.toFixed(2) %> FRW
              </td>
              <td class="px-4 py-2 text-center">
                <% if (student.balance === 0) { %>
                <span class="bg-green-100 text-green-800 px-2 py-1 rounded text-xs font-bold">Paid</span>
                <% } else if (student.amountPaid > 0) { %>
                <span class="bg-yellow-100 text-yellow-800 px-2 py-1 rounded text-xs font-bold">Partial</span>
                <% } else { %>
                <span class="bg-red-100 text-red-800 px-2 py-1 rounded text-xs font-bold">Unpaid</span>
                <% } %>
              </td>
            </tr>
            <% }) %>
            <% } %>
          </tbody>
          <tfoot class="bg-gray-100 font-bold">
            <tr>
              <td colspan="3" class="px-4 py-3 text-right">TOTALS:</td>
              <td class="px-4 py-3 text-right"><%= totalFees.toFixed(2) %> FRW</td>
              <td class="px-4 py-3 text-right text-green-600"><%= totalPaid.toFixed(2) %> FRW</td>
              <td class="px-4 py-3 text-right text-red-600"><%= totalBalance.toFixed(2) %> FRW</td>
              <td></td>
            </tr>
          </tfoot>
        </table>
      </div>
    </div>

    <div class="mt-6 text-center text-gray-600 text-sm">
      <p>Report generated on <%= new Date().toLocaleString() %></p>
      <p>Generated by: <%= user.username %> (<%= user.role %>)</p>
    </div>
  </div>

  <style>
    @media print {
      nav, button, a[href="/reports"] { display: none; }
      body { background: white; }
    }
  </style>
</body>
</html>
