<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Record Payment</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100">
  <nav class="bg-blue-600 text-white p-4">
    <div class="container mx-auto flex justify-between items-center">
      <h1 class="text-2xl font-bold">School Fees Management</h1>
      <div class="flex gap-4 items-center">
        <a href="/dashboard" class="hover:underline">Dashboard</a>
        <a href="/students" class="hover:underline">Students</a>
        <% if (user.role === 'admin') { %>
        <a href="/staff" class="hover:underline">Staff</a>
        <% } %>
        <a href="/auth/logout" class="bg-red-500 px-4 py-2 rounded hover:bg-red-600">Logout</a>
      </div>
    </div>
  </nav>

  <div class="container mx-auto p-6 max-w-2xl">
    <h2 class="text-3xl font-bold mb-6">Record Payment</h2>
    
    <% if (error && error.length > 0) { %>
    <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4">
      <%= error %>
    </div>
    <% } %>

    <div class="bg-white p-6 rounded-lg shadow mb-6">
      <h3 class="text-xl font-bold mb-4">Student Information</h3>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <p class="text-gray-600">Full Name</p>
          <p class="font-bold"><%= student.fullName %></p>
        </div>
        <div>
          <p class="text-gray-600">Registration Number</p>
          <p class="font-bold"><%= student.registrationNumber %></p>
        </div>
        <div>
          <p class="text-gray-600">Class</p>
          <p class="font-bold"><%= student.class ? student.class.name : 'N/A' %></p>
        </div>
        <div>
          <p class="text-gray-600">Level</p>
          <p class="font-bold"><%= student.level %></p>
        </div>
        <div>
          <p class="text-gray-600">Total Fees</p>
          <p class="font-bold"><%= student.totalFees.toFixed(2) %> FRW</p>
        </div>
        <div>
          <p class="text-gray-600">Amount Paid</p>
          <p class="font-bold text-green-600"><%= student.amountPaid.toFixed(2) %> FRW</p>
        </div>
        <div>
          <p class="text-gray-600">Balance</p>
          <p class="font-bold text-red-600"><%= student.balance.toFixed(2) %> FRW</p>
        </div>
      </div>
    </div>

    <form method="POST" class="bg-white p-6 rounded-lg shadow">
      <div class="mb-6">
        <label class="block text-gray-700 mb-2">Payment Amount</label>
        <input type="number" name="amount" step="0.01" min="0.01" max="<%= student.balance %>" required 
               class="w-full px-4 py-2 border rounded focus:outline-none focus:ring-2 focus:ring-blue-500">
        <p class="text-sm text-gray-500 mt-1">Maximum: <%= student.balance.toFixed(2) %> FRW</p>
      </div>

      <div class="flex gap-4">
        <button type="submit" 
                class="flex-1 bg-green-600 text-white py-2 rounded hover:bg-green-700">
          Record Payment
        </button>
        <a href="/students" 
           class="flex-1 bg-gray-500 text-white py-2 rounded hover:bg-gray-600 text-center">
          Cancel
        </a>
      </div>
    </form>

    <% if (student.payments.length > 0) { %>
    <div class="bg-white p-6 rounded-lg shadow mt-6">
      <h3 class="text-xl font-bold mb-4">Payment History</h3>
      <table class="w-full">
        <thead class="bg-gray-200">
          <tr>
            <th class="px-4 py-2 text-left">Date</th>
            <th class="px-4 py-2 text-right">Amount</th>
            <th class="px-4 py-2 text-left">Recorded By</th>
          </tr>
        </thead>
        <tbody>
          <% student.payments.forEach(payment => { %>
          <tr class="border-t">
            <td class="px-4 py-2"><%= new Date(payment.date).toLocaleString() %></td>
            <td class="px-4 py-2 text-right"><%= payment.amount.toFixed(2) %> FRW</td>
            <td class="px-4 py-2"><%= payment.recordedBy %></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } %>
  </div>
</body>
</html>
